        { "type": "image", "src": "assets/media/morro/morro-2.jpg",  "alt": "MORRO image 2",  "caption": "Visual introduction to the style." },
        { "type": "image", "src": "assets/media/morro/morro-3.jpg",  "alt": "MORRO image 3",  "caption": "Introduction of the word \"Mucho\" (meaning \"a lot\" - \"having a lot of nerve\")" },
        { "type": "image", "src": "assets/media/morro/morro-4.jpg",  "alt": "MORRO image 4",  "caption": "Introduction to the isotype." },
