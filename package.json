    "build": "node scripts/build.js && node scripts/build-sitemap.js",
    "preview": "npm run build && node scripts/preview.js"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "sharp": "^0.33.5"
  }
}
