{
  "name": "menendezmorro-portfolio",
  "version": "0.1.0",
  "private": true,
  "description": "Portfolio of design and photography projects by Martí Menéndez. Vanilla HTML/CSS/JS, deployed on GitHub Pages, edited through Decap CMS.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "validate": "node scripts/validate-data.js",
